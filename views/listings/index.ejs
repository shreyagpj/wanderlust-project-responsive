<%- layout("layouts/boilerplate") -%>
<style>
/* FILTER BAR */
.filters{
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  overflow-x: auto;
  padding-bottom: 0.5rem;
  flex-wrap: nowrap;
  width: 100%;
}

.filters::-webkit-scrollbar{
  display: none;
}

.filter{
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 0.9rem;
  width: 50px;
}

.filter i{
  font-size: 1.2rem;
  margin-bottom: 0.2rem;
}

/* TAX TOGGLE */
.tax-toggle{
  border: 1px solid #dddddd;
  border-radius: 12px;
  padding: 0.8rem 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 20rem;
  background-color: white;
  font-size: 0.95rem;
  font-weight: 500;
  margin-left: 0;
}

.tax-toggle:hover{
  border-color: #b0b0b0;
}

.tax-text{
  color: #222;
  font-weight: 450;
}

.form-check-input{
  cursor: pointer;
}

.taxes{
  font-size: smaller;
}

/* CARD IMAGE */
.card-img-top{
  height: 250px;
  object-fit: cover;
  border-radius: 10px;
}

/* MOBILE RESPONSIVENESS */
@media (max-width: 768px){

  .filters{
    gap: 1rem;
  }

  .filter{
    font-size: 0.8rem;
    min-width: 70px;
  }

  .filter i{
    font-size: 1rem;
  }

  .tax-toggle{
    width: auto;
    min-width: 200px;
    font-size: 0.85rem;
  }

  .card-img-top{
    height: 200px;
  }
  /* Hide tax toggle on small screens */


/* NAVBAR RESPONSIVE RULES */
@media (max-width: 768px){

  /* Hide explore text */
  .explore-link{
    display: none !important;
  }

  /* Keep logo + search bar visible */
  .navbar{
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Search bar responsive */
  .search-bar{
    flex: 1;
    margin: 0 10px;
  }

}

/* Optional: improve navbar spacing for very small screens */
@media (max-width: 480px){

  .search-bar{
    width: 100%;
    margin: 0 5px;
  }

}

.tax-toggle{
  min-width: 200px;
  width: auto;
}

}

/* SMALL PHONES */
@media (max-width: 480px){

  .filters{
    gap: 0.8rem;
  }

  .filter{
    min-width: 60px;
    font-size: 0.75rem;
  }

  .card-img-top{
    height: 180px;
  }

}

@media (max-width: 1000px){

  .tax-toggle{
      display: none
  }

}
</style>
    <body>
        <%- include("../includes/flash.ejs") -%><%- include("../includes/error.ejs")
    -%>
     <%- include("../includes/success.ejs") -%>
        <div class="filters mt-5 mb-5">


  <a href="/listings/category/beaches" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-umbrella-beach"></i></div>
    Beaches
  </a>

  <a href="/listings/category/mountains" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-mountain"></i></div>
    Mountains
  </a>

  <a href="/listings/category/forest" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-tree"></i></div>
    Forest
  </a>

  <a href="/listings/category/camping" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-campground"></i></div>
    Camping
  </a>

  <a href="/listings/category/arctic" class="filter text-decoration-none text-dark">
    <div><i class="fa-regular fa-snowflake"></i></div>
    Arctic
  </a>

  <a href="/listings/category/cities" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-city"></i></div>
    Cities
  </a>

  <a href="/listings/category/castles" class="filter text-decoration-none text-dark">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    Castles
  </a>

  <a href="/listings/category/wellness" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-spa"></i></div>
    Wellness
  </a>

  <a href="/listings/category/luxury" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-gem"></i></div>
    Luxury
  </a>
  <div class="tax-toggle">
  <span class="tax-text">Display total after taxes</span>

  <div class="form-check form-switch m-0">
    <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
  </div>
</div>
</div>

        <hr>
        <br>
        <br>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 row-cols-xl-4">
  <% for (listing of list) { %>
    <div class="col">
      <a href="/listings/<%= listing.id %>/view" class="listing-card text-decoration-none">
        <div class="card h-100 listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image">
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377;<%= listing.price.toLocaleString("en-IN") %>/night <i class="taxes" style="display: none"> + 18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("click", () => {
  console.log("clicked");

  let gst = document.getElementsByClassName("taxes");

  for (let prices of gst) {
    if (prices.style.display === "none") {
      prices.style.display = "inline";
    } else {
      prices.style.display = "none";
    }
  }
});
</script>
    </body>