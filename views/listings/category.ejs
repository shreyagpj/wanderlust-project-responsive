<%- layout("layouts/boilerplate") -%>
<style>
  .tax-toggle{
  border: 1px solid #dddddd;
  border-radius: 12px;
  padding: 0.8rem 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 18rem;
  background-color: white;
  font-size: 0.95rem;
  font-weight: 500;
}

.tax-toggle:hover{
  border-color: #b0b0b0;
}

.tax-text{
  color: #222;
  font-weight: 450;
}

.form-check-input{
  cursor: pointer;
}
.taxes{
  font-size: smaller
}
</style>
<body>
  <%- include("../includes/flash.ejs") -%>
  <%- include("../includes/error.ejs") -%>
  <%- include("../includes/success.ejs") -%>

  <div class="filters mt-5 mb-5">


  <a href="/listings/category/beaches" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-umbrella-beach"></i></div>
    Beaches
  </a>

  <a href="/listings/category/mountains" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-mountain"></i></div>
    Mountains
  </a>

  <a href="/listings/category/forest" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-tree"></i></div>
    Forest
  </a>

  <a href="/listings/category/camping" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-campground"></i></div>
    Camping
  </a>

  <a href="/listings/category/arctic" class="filter text-decoration-none text-dark">
    <div><i class="fa-regular fa-snowflake"></i></div>
    Arctic
  </a>

  <a href="/listings/category/cities" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-city"></i></div>
    Cities
  </a>

  <a href="/listings/category/castles" class="filter text-decoration-none text-dark">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    Castles
  </a>

  <a href="/listings/category/wellness" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-spa"></i></div>
    Wellness
  </a>

  <a href="/listings/category/luxury" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-gem"></i></div>
    Luxury
  </a>
  <div class="tax-toggle">
  <span class="tax-text">Display total after taxes</span>

  <div class="form-check form-switch m-0">
    <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
  </div>
</div>
</div>

  <hr><br><br>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 row-cols-xl-4">
    <% list.forEach(listing => { %>
      <div class="col">
        <a href="/listings/<%= listing.id %>/view" class="listing-card text-decoration-none">
          <div class="card h-100 listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image">
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %>/night  <i class="taxes" style="display: none"> + 18% GST</i>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
  
<script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("click", () => {
  console.log("clicked");

  let gst = document.getElementsByClassName("taxes");

  for (let prices of gst) {
    if (prices.style.display === "none") {
      prices.style.display = "inline";
    } else {
      prices.style.display = "none";
    }
  }
});
</script>
</body>