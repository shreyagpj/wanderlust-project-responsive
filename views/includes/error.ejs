<% if (error && error.length) { %>
  <div class="alert alert-danger alert-dismissible fade show mt-3 col-10 mx-auto" role="alert">
    <%= error %>
    <button type="button" 
            class="btn-close" 
            data-bs-dismiss="alert" 
            aria-label="Close">
    </button>
  </div>
<% } %>