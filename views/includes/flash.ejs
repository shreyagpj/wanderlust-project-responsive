<% if (msg && msg.length) { %>
  <div class="alert alert-success alert-dismissible fade show mt-3 col-10 mx-auto" role="alert">
    <%= msg %>
    <button type="button" 
            class="btn-close" 
            data-bs-dismiss="alert" 
            aria-label="Close">
    </button>
  </div>
<% } %>